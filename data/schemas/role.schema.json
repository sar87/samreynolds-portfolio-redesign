{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "role.schema.json",
  "title": "Roles Schema",
  "description": "Schema for other employment, memberships and voluntary roles",
  "type": "object",
  "required": ["roles"],
  "properties": {
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "period", "title"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the role"
          },
          "period": {
            "type": "string",
            "description": "Time period as displayed (e.g. '2025 – Ongoing')"
          },
          "title": {
            "type": "string",
            "description": "Role title"
          },
          "detail": {
            "type": "string",
            "description": "Additional context (organisation, remit); may be empty"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
